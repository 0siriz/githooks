#!/usr/bin/env bash

# Put into the directory specified by core.hooksPath or just `.git/hooks/`
# Then symlink each hookname to this script
# Hooks go in `HOOKNAME.d/` e.g. `pre-commit.d/00-hook1`
# Hooks are taken from the following directories
# from the location of this script:
# - $GIT_DIR/hooks/HOOKNAME.d/*
# - $GIT_CUSTOM_HOOKS_DIR/HOOKNAME.d/*
# - ./HOOKNAME.d/*

set -eEu -o pipefail
shopt -s inherit_errexit

BOLD=$(echo -e "\x1b[1m")
RED=$(echo -e "\x1b[31m")
GREEN=$(echo -e "\x1b[32m")
YELLOW=$(echo -e "\x1b[33m")
MAGENTA=$(echo -e "\x1b[35m")
CYAN=$(echo -e "\x1b[36m")
RESET=$(echo -e "\x1b[0m")

function truncate_path() {
	local path="$1"
	local max_len="$2"

	(( ${#path} <= max_len )) && {
		echo "$path"
		return
	}

	local is_abs=0
	[[ "$path" == /* ]] && is_abs=1

	local IFS='/'
	read -ra parts <<< "${path#/}"

	local total=${#parts[@]}

	local changed=1
	while (( ${#path} > max_len && changed )); do
		changed=0

		for (( i=1; i<total-1; i++ )); do
			local part="${parts[i]}"

			if (( ${#part} > 1 )); then
				parts[i]="${part:0:1}"
				changed=1

				local joined=$(IFS=/; echo "${parts[*]}")

				if (( is_abs )); then
					path="/${joined}"
				else
					path="$joined"
				fi

				(( ${#path} <= max_len )) && break
			fi
		done
	done

	if (( ${#path} > max_len && total > 2 )); then
		local start="${parts[0]}"
		local end="${parts[total-1]}"

		if (( is_abs )); then
			path="/${start}/.../$end"
		else
			path="${start}/.../$end"
		fi
	fi

	if (( ${#path} > max_len )); then
		path="${path:0:max_len-3}..."
	fi

	echo "$path"
}

format_hook() {
	local hookname="$1"
	local max_len="$2"

	hookname=$(truncate_path "$hookname" $((max_len - 20)))

	local output="[HOOK] ${hookname}"

	local dotcount=$((max_len - ${#output} - 10))
	local dots=""

	for (( i=0; i<dotcount; i++ )); do
		dots="${dots}."
	done

	echo -n "${MAGENTA}${output}${RESET} ${dots} "
}

# optional debug output by TRACE=1
[[ "${TRACE:-0}" == "1" ]] && set -o xtrace
IFS=$'\n\t'
PS4='+\t '

STDIN=$(cat)

[[ -n "${GIT_DIR:-}" ]] && git_dir="$GIT_DIR"
unset $(git rev-parse --local-env-vars || true)
GIT_DIR="$(git rev-parse --git-dir 2>/dev/null)" || GIT_DIR="$git_dir"
export GIT_DIR
[[ -n "${git_dir:-}" ]] && unset git_dir

declare -a HOOKDIRS
HOOKDIRS+=("$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)")
[[ -n "${GIT_CUSTOM_HOOKS_DIR:-}" ]] && HOOKDIRS+=("$GIT_CUSTOM_HOOKS_DIR")
HOOKDIRS+=("$GIT_DIR/hooks")

HOOKNAME=$(basename "${BASH_SOURCE[0]}")

echo "${CYAN}[START] Running ${HOOKNAME} hooks ${RESET}"

declare -A TO_RUN

for dir in "${HOOKDIRS[@]}"; do
	hookdir="${dir}/${HOOKNAME}.d"
	if [[ -d "$hookdir" ]]; then
		for hook in "$hookdir"/*; do
			hookname="$(basename "$hook")"
			TO_RUN[$hookname]="$hook"
		done
	fi
done

declare -a FAILED=()
declare -a SKIPPED=()
declare -a PASSED=()

while read -r hookname; do
	hookscript="${TO_RUN[$hookname]}"
	if [[ -f "$hookscript" && -x "$hookscript" ]]; then
		hookname="$hookscript"
		[[ "$hookname" =~ ^"$HOME"(/|$) ]] && hookname="~${hookname#$HOME}"
		exit_code=0
		columns=$(tput cols)
		format_hook "${hookname}" $((columns>40 ? columns<80 ? columns : 80 : 40))
		output=$(echo "$STDIN" | "$hookscript" "$@" 2>&1) || exit_code=$?

		if [[ $exit_code -eq 0 ]]; then
			PASSED+=("$hookname")
			echo "${GREEN}Passed${RESET}"
		elif [[ $exit_code -eq 2 ]]; then
			SKIPPED=("$hookname")
			echo "${YELLOW}Skipped${RESET}"
			echo "${output}"
			echo ""
		else
			FAILED+=("$hookname")
			echo "${RED}Failed${RESET}"
			echo "${output}"
			echo ""
		fi
	fi
done < <(
	for key in "${!TO_RUN[@]}"; do
		echo "$key"
	done | sort
)

echo "${CYAN}[END] Summary of ${HOOKNAME} hooks ${RESET}"

if [[ "${#PASSED[@]}" -gt 0 ]]; then
	echo "${GREEN}Passed: ${#PASSED[@]}${RESET}"
fi

if [[ "${#SKIPPED[@]}" -gt 0 ]]; then
	echo "${YELLOW}Skipped: ${#SKIPPED[@]}${RESET}"
fi

if [[ "${#FAILED[@]}" -gt 0 ]]; then
	echo "${RED}Failed: ${#FAILED[@]}${RESET}"
fi

echo ""

[[ "${#FAILED[@]}" -eq 0 ]] || exit 1
